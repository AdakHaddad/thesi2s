# ========================================
# Vitis Workspace / IDE Generated Files
# ========================================
workspace/_ide/
workspace/.rigel_lopper/
workspace/**/.cache/
workspace/**/.clangd/
workspace/**/build/
workspace/**/export/
workspace/**/logs/
